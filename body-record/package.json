{
  "name": "body-record",
  "version": "0.1.0",
  "private": true,
  "description": "体重・体組成記録 PWA（RecStyle 乗り換え用 / GitHub Pages / オフライン対応）",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
